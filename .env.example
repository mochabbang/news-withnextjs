# Korea news uses RSS by default (no key required).
# Below keys are optional fallbacks/boost for Korea, and required for non-Korea countries.

# Required for non-Korean countries (NewsAPI.org top-headlines).
NEWS_API_KEY=

# Optional: extra Korean providers tried after RSS fails.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GNEWS_API_KEY=
NEWSDATA_API_KEY=
CURRENTS_API_KEY=

# Optional Korean translation for non-Korean NewsAPI headlines.
# none | mymemory | libretranslate
NEWS_TRANSLATE_PROVIDER=none
MYMEMORY_EMAIL=
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
TRANSLATE_MAX_ARTICLES=5

# AI summary (OpenAI). When set, each visible card lazy-fetches a one-line Korean summary.
OPENAI_API_KEY=
# Optional: override default summary model (default: gpt-4o-mini).
SUMMARY_MODEL=
